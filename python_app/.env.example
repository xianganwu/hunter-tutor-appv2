# Hunter Tutor — Python App Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Required: JWT secret (minimum 32 characters, use a random string)
JWT_SECRET=your-secret-key-min-32-chars-here

# Database URL (SQLite for local dev, or PostgreSQL for production)
DATABASE_URL=sqlite:///./dev.db

# App settings
APP_NAME="Hunter Tutor"
APP_URL=http://localhost:8000

# Optional: default parent PIN (not recommended for production)
PARENT_PIN=1234

# Set to true for debug mode (enables SQL logging, etc.)
DEBUG=false
