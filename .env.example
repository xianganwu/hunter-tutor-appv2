# Anthropic API key (required — server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Turso database URL (required)
# Local development: "file:./dev.db"
# Production: "libsql://your-db-name-your-org.turso.io"
TURSO_DATABASE_URL="file:./dev.db"

# Turso auth token (required for production, omit for local SQLite)
TURSO_AUTH_TOKEN=

# Public app URL (used for metadata, OG tags, canonical URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
NEXT_PUBLIC_APP_NAME="Hunter Tutor"
PARENT_PIN="1234"
